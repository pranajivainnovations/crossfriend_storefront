## 10. Database Schema to Add

### `ai_generations` table
```sql
CREATE TABLE ai_generations (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  customer_id VARCHAR NOT NULL,
  prompt TEXT NOT NULL,
  occasion VARCHAR(50),
  style VARCHAR(50),
  flavor VARCHAR(50),
  zodiac_sign VARCHAR(20),
  provider VARCHAR(30) NOT NULL,
  provider_model VARCHAR(50),
  status VARCHAR(20) NOT NULL DEFAULT 'pending',
  image_urls JSONB DEFAULT '[]',
  image_count INT DEFAULT 0,
  credit_cost INT DEFAULT 1,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  completed_at TIMESTAMPTZ,
  failed_reason TEXT,
  metadata JSONB DEFAULT '{}',
  CONSTRAINT fk_customer FOREIGN KEY (customer_id) REFERENCES customer(id)
);

CREATE INDEX idx_ai_gen_customer ON ai_generations(customer_id);
CREATE INDEX idx_ai_gen_status ON ai_generations(status);
CREATE INDEX idx_ai_gen_created ON ai_generations(created_at DESC);
```

### `cake_leads` table
```sql
CREATE TABLE cake_leads (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  customer_id VARCHAR NOT NULL,
  generation_id UUID REFERENCES ai_generations(id),
  design_image_url TEXT,
  baker_id VARCHAR,
  pincode VARCHAR(6),
  weight VARCHAR(10),
  tiers VARCHAR(5),
  shape VARCHAR(30),
  flavor VARCHAR(50),
  addons JSONB DEFAULT '[]',
  estimated_price INT,
  message TEXT,
  status VARCHAR(20) DEFAULT 'new',
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW(),
  CONSTRAINT fk_lead_customer FOREIGN KEY (customer_id) REFERENCES customer(id)
);

CREATE INDEX idx_leads_customer ON cake_leads(customer_id);
CREATE INDEX idx_leads_status ON cake_leads(status);
```

